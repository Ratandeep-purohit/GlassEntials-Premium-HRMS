# ============================================================
# GlassEntials HRMS — Environment Variables Reference
# ============================================================
# Copy this file to .env for local development.
# On AWS, set these as Environment Properties (Elastic Beanstalk),
# ECS Task Definition secrets, or EC2 Parameter Store values.
# NEVER commit your real .env to version control.
# ============================================================


# --- Django Core ---
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=hrms.yourdomain.com,your-alb-dns.ap-south-1.elb.amazonaws.com

# --- CSRF (required behind AWS ALB over HTTPS) ---
# Must use full origin: scheme + hostname, no trailing slash
DJANGO_CSRF_TRUSTED_ORIGINS=https://hrms.yourdomain.com,https://your-alb-dns.ap-south-1.elb.amazonaws.com

# --- Database (AWS RDS MySQL) ---
DB_NAME=HRMS_db
DB_USER=hrms_user
DB_PASSWORD=your-rds-password
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_CONN_MAX_AGE=60

# --- AWS S3 (Media File Storage) ---
# Set USE_S3=True in production, False for local development
USE_S3=True
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_STORAGE_BUCKET_NAME=glassentials-hrms-media
AWS_S3_REGION_NAME=ap-south-1

# --- Django Security (auto-enabled when DEBUG=False) ---
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000

# --- Logging ---
DJANGO_LOG_LEVEL=WARNING

# --- Server / Gunicorn (Dockerfile) ---
GUNICORN_WORKERS=5
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# --- Admin Security ---
DJANGO_ADMIN_URL=super-secret-admin/
